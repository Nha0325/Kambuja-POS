# ==========================================
# KAMBUJA POS - BACKEND ENVIRONMENT EXAMPLE
# ==========================================

# 1. Server Configuration
NODE_ENV=development
PORT=8080

# 2. Database (MongoDB)
MONGODB_URI=mongodb://localhost:27017/kambuja_pos

# 3. Security & Authentication (JWT & Cookies)
JWT_SECRET=replace-with-a-random-secret-at-least-32-bytes
JWT_LIFETIME=60m
COOKIE_EXPIRE=1
COOKIE_SAMESITE=lax

# 4. Default Super Admin (Bootstrap)
BOOTSTRAP_ADMIN_MANAGER_NAME=pkay
BOOTSTRAP_ADMIN_MANAGER_EMAIL=pkay@gmail.com
BOOTSTRAP_ADMIN_MANAGER_PASSWORD=pkay12345678

# 5. CORS & Domains (Frontend URLs)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
LOCAL_DOMAIN=http://localhost:5173
CLIENT_DOMAIN=http://localhost:5174

# 6. Cloudinary (Image Uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
