# Local Backend development configuration. Copy to Backend/.env.

# App
NODE_ENV=development
PORT=8080

# MongoDB
MONGODB_URI=mongodb://localhost:27017/kambuja_pos

# JWT
JWT_SECRET=replace-with-a-random-secret-at-least-32-bytes
JWT_LIFETIME=60m

# Bootstrap Super Admin
BOOTSTRAP_ADMIN_MANAGER_NAME=Platform Manager
BOOTSTRAP_ADMIN_MANAGER_EMAIL=manager@kambujaflow.local
BOOTSTRAP_ADMIN_MANAGER_PASSWORD=change-me-before-production

# Authentication cookie
COOKIE_EXPIRE=1
COOKIE_DOMAIN=localhost
COOKIE_SAMESITE=lax

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
LOCAL_DOMAIN=http://localhost:5173
CLIENT_DOMAIN=http://localhost:5174
