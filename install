#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo "=== Kambuja POS Automatic Setup ==="
echo

# 1. Setup Environment Variables
if [ ! -f "$ROOT_DIR/.env" ]; then
    echo "[*] Creating .env file from .env.example..."
    cp "$ROOT_DIR/.env.example" "$ROOT_DIR/.env"
else
    echo "[*] .env file already exists. (Skipping)"
fi

# 2. Check and Install Docker
if ! command -v docker &> /dev/null; then
    echo "[*] Docker is missing. Installing Docker..."
    if command -v apt &> /dev/null; then
        sudo apt update
        sudo apt install docker.io -y
        sudo systemctl start docker
        sudo systemctl enable docker
    else
        echo "[!] Cannot install Docker automatically. Please install Docker manually."
        exit 1
    fi
else
    echo "[*] Docker is already installed. (Skipping)"
fi

# 3. Check and Start MongoDB Container
echo "[*] Preparing MongoDB container..."
if ! sudo docker ps -a --format '{{.Names}}' | grep -Eq "^kambuja-pos-mongo\$"; then
    echo "    -> Creating new MongoDB container..."
    sudo docker run -d \
      --name kambuja-pos-mongo \
      -p 27017:27017 \
      -v kambuja-pos-mongo-data:/data/db \
      mongo:7
else
    echo "    -> Container kambuja-pos-mongo already exists. Starting it..."
    sudo docker start kambuja-pos-mongo
fi

# 4. Install Project Dependencies
echo "[*] Installing project dependencies (Maven/NPM)..."
if [ -x "$ROOT_DIR/scripts/sh/setup.sh" ]; then
    "$ROOT_DIR/scripts/sh/setup.sh"
elif [ -f "$ROOT_DIR/scripts/sh/setup.sh" ]; then
    bash "$ROOT_DIR/scripts/sh/setup.sh"
else
    echo "[!] Cannot find setup.sh script."
fi

# 5. Install Additional Frontend Packages
echo "[*] Installing additional frontend packages..."
for APP in "apps/web-admin-manager" "apps/web-admin"; do
    if [ -d "$ROOT_DIR/$APP" ]; then
        echo "    -> Installing in $APP..."
        (cd "$ROOT_DIR/$APP" && npm install react-router-dom zustand framer-motion react-icons lenis tailwindcss @tailwindcss/vite axios eslint)
    fi
done

echo
echo "========================================="
echo " 🎉 Setup Complete Successfully! 🎉 "
echo "========================================="
echo
echo "To start all applications, run:"
echo "   ./scripts/sh/dev.sh"
echo
echo "Default URLs:"
echo "   API:                   http://localhost:8080"
echo "   Swagger:               http://localhost:8080/swagger-ui.html"
echo "   Admin Manager UI:      http://localhost:5173"
echo "   Admin and Cashier UI:  http://localhost:5174"
echo "========================================="
