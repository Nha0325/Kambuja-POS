#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo "Kambuja POS setup"
echo
echo "1. Copy environment configuration:"
echo "   cp \"$ROOT_DIR/.env.example\" \"$ROOT_DIR/.env\""
echo
echo "2. Install dependencies:"
echo "   \"$ROOT_DIR/scripts/setup.sh\""
echo
echo "3. Start MongoDB."
echo
echo "4. Start all applications:"
echo "   \"$ROOT_DIR/scripts/dev.sh\""
echo
echo "5. Validate all applications:"
echo "   \"$ROOT_DIR/scripts/test.sh\""
echo
echo "6. Optional sample data:"
echo "   \"$ROOT_DIR/scripts/seed.sh\""
echo
echo "Default URLs:"
echo "   API:                   http://localhost:8080"
echo "   Swagger:               http://localhost:8080/swagger-ui.html"
echo "   Health:                http://localhost:8081/actuator/health"
echo "   Prometheus metrics:    http://localhost:8081/actuator/prometheus"
echo "   Admin Manager UI:      http://localhost:5173"
echo "   Admin and Cashier UI:  http://localhost:5174"
