#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo "========================================="
echo "   🚀 Kambuja POS Automatic Setup 🚀   "
echo "========================================="
echo

# 1. Setup Environment Variables
echo "[*] 1. Setting up Environment Variables..."

# Root .env
if [ ! -f "$ROOT_DIR/.env" ] && [ -f "$ROOT_DIR/.env.example" ]; then
    echo "    -> Creating root .env file..."
    cp "$ROOT_DIR/.env.example" "$ROOT_DIR/.env"
else
    echo "    -> Root .env already exists or .env.example missing. (Skipping)"
fi

# Backend .env
if [ ! -f "$ROOT_DIR/Backend/.env" ] && [ -f "$ROOT_DIR/Backend/.env.example" ]; then
    echo "    -> Creating Backend/.env file..."
    cp "$ROOT_DIR/Backend/.env.example" "$ROOT_DIR/Backend/.env"
else
    echo "    -> Backend/.env already exists or .env.example missing. (Skipping)"
fi

# Frontend .env
if [ ! -f "$ROOT_DIR/Frontend/.env" ] && [ -f "$ROOT_DIR/Frontend/.env.example" ]; then
    echo "    -> Creating Frontend/.env file..."
    cp "$ROOT_DIR/Frontend/.env.example" "$ROOT_DIR/Frontend/.env"
else
    echo "    -> Frontend/.env already exists or .env.example missing. (Skipping)"
fi
echo

# 2. Install Backend Dependencies
echo "[*] 2. Installing Backend Dependencies (Node.js)..."
if [ -d "$ROOT_DIR/Backend" ]; then
    (cd "$ROOT_DIR/Backend" && npm install)
    echo "    -> Backend dependencies installed successfully!"
else
    echo "    -> [!] Backend folder not found."
fi
echo

# 3. Install Frontend Dependencies
echo "[*] 3. Installing Frontend Dependencies (React.js)..."
if [ -d "$ROOT_DIR/Frontend" ]; then
    (cd "$ROOT_DIR/Frontend" && npm install)
    echo "    -> Frontend dependencies installed successfully!"
else
    echo "    -> [!] Frontend folder not found."
fi
echo

echo "========================================="
echo " 🎉 Setup Complete Successfully! 🎉 "
echo "========================================="
echo
echo "To start the application locally, open TWO terminals:"
echo
echo "Terminal 1 (Backend):"
echo "   cd Backend"
echo "   npm run dev"
echo
echo "Terminal 2 (Frontend):"
echo "   cd Frontend"
echo "   npm run dev"
echo "========================================="
