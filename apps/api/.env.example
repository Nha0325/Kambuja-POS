# App
APP_NAME=kambuja-pos-api
SERVER_PORT=8080
BACKEND_BASE_URL=http://localhost:8080

# MongoDB
MONGODB_URI=mongodb://localhost:27017/kambuja_pos

# JWT
JWT_SECRET=replace_with_a_random_64_character_or_longer_secret
JWT_ISSUER=kambuja-pos-api
JWT_ACCESS_TOKEN_MINUTES=60

# Bootstrap admin manager
BOOTSTRAP_ADMIN_MANAGER_NAME=Platform Manager
BOOTSTRAP_ADMIN_MANAGER_EMAIL=manager@kambujaflow.local
BOOTSTRAP_ADMIN_MANAGER_PASSWORD=change-me-before-production

# CORS
CORS_ENABLED=true
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
CORS_ALLOWED_METHODS=GET,POST,PATCH,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Requested-With,X-Request-Id
CORS_EXPOSED_HEADERS=X-Request-Id
CORS_MAX_AGE_SECONDS=1800
CORS_ALLOW_CREDENTIALS=false

# API logging
API_LOGGING_ENABLED=true
API_LOGGING_INCLUDE_QUERY_STRING=false
API_LOGGING_INCLUDE_HEALTH_CHECKS=false

# WAF
WAF_ENABLED=true
WAF_AUDIT_ONLY=false
WAF_PROTECTED_PATH_PREFIXES=/api
WAF_ALLOWED_METHODS=GET,POST,PATCH,PUT,DELETE,OPTIONS
WAF_MAX_URI_LENGTH=2048
WAF_MAX_QUERY_LENGTH=2048
WAF_MAX_BODY_BYTES=65536
WAF_MAX_HEADER_VALUE_LENGTH=4096
WAF_MAX_HEADER_COUNT=80
WAF_MAX_REQUESTS_PER_MINUTE=120

# Rate limit
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_FAIL_CLOSED=true

# Upload
UPLOAD_MAX_FILE_SIZE=5MB
UPLOAD_MAX_REQUEST_SIZE=25MB
UPLOAD_VALIDATION_ENABLED=true
UPLOAD_MAX_FILE_SIZE_BYTES=5242880
UPLOAD_MAX_FILES=5
UPLOAD_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp,application/pdf
UPLOAD_ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.webp,.pdf
UPLOAD_VERIFY_SIGNATURES=true

# Storage
STORAGE_PROVIDER=local
LOCAL_UPLOAD_DIR=uploads
PUBLIC_UPLOAD_BASE_URL=http://localhost:8080/uploads

# Telegram notification bot
TELEGRAM_BOT_TOKEN=replace_with_botfather_token
