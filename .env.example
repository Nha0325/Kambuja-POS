# ==========================================
# KAMBUJA POS - DOCKER ENVIRONMENT EXAMPLE
# ==========================================
# Note: This is only used for docker-compose

APP_NAME=kambuja-pos-api
NODE_ENV=development
PORT=8080
MONGODB_URI=mongodb://mongo:27017/kambuja_pos
JWT_SECRET=replace-with-a-random-secret-at-least-32-bytes
JWT_LIFETIME=60m

BOOTSTRAP_ADMIN_MANAGER_NAME=Platform Manager
BOOTSTRAP_ADMIN_MANAGER_EMAIL=manager@kambujaflow.local
BOOTSTRAP_ADMIN_MANAGER_PASSWORD=change-me-before-production

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
