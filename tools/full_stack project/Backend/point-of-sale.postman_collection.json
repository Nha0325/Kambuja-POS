{
  "info": {
    "name": "point-of-sale",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signin",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"pkay@gmail.com\",\n  \"password\": \"pkay12345678\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/signin" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "  var json = pm.response.json();",
                  "  if (json.result && json.result.token) {",
                  "    pm.collectionVariables.set('token', json.result.token);",
                  "    console.log('Saved token to collection variable');",
                  "  }",
                  "} catch (e) { console.log(e); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Cookie", "value": "token={{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/me" }
          }
        },
        {
          "name": "Signout",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Cookie", "value": "token={{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/signout" }
          }
        }
      ]
    },
    {
      "name": "Category",
      "item": [
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie", "value": "token={{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Beverage\",\n  \"noe\": \"drink\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/categories" }
          }
        },
        {
          "name": "List Categories",
          "request": { "method": "GET", "header": [{ "key": "Cookie", "value": "token={{token}}" }], "url": { "raw": "{{baseUrl}}/api/v1/categories" } }
        },
        {
          "name": "Get Category",
          "request": { "method": "GET", "header": [{ "key": "Cookie", "value": "token={{token}}" }], "url": { "raw": "{{baseUrl}}/api/v1/categories/:id" } }
        },
        {
          "name": "Update Category",
          "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Cookie", "value": "token={{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Drinks\"\n}" }, "url": { "raw": "{{baseUrl}}/api/v1/categories/:id" } }
        },
        {
          "name": "Delete Category",
          "request": { "method": "DELETE", "header": [{ "key": "Cookie", "value": "token={{token}}" }], "url": { "raw": "{{baseUrl}}/api/v1/categories/:id" } }
        }
      ]
    },
    {
      "name": "Customer",
      "item": [
        { "name": "Create Customer", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Cookie", "value": "token={{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\"\n}" }, "url": { "raw": "{{baseUrl}}/api/v1/customers" } } },
        { "name": "List Customers", "request": { "method": "GET", "header": [{ "key": "Cookie", "value": "token={{token}}" }], "url": { "raw": "{{baseUrl}}/api/v1/customers" } } },
        { "name": "Get Customer", "request": { "method": "GET", "header": [{ "key": "Cookie", "value": "token={{token}}" }], "url": { "raw": "{{baseUrl}}/api/v1/customers/:id" } } },
        { "name": "Update Customer", "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Cookie", "value": "token={{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"phone\": \"0912345678\"\n}" }, "url": { "raw": "{{baseUrl}}/api/v1/customers/:id" } } },
        { "name": "Delete Customer", "request": { "method": "DELETE", "header": [{ "key": "Cookie", "value": "token={{token}}" }], "url": { "raw": "{{baseUrl}}/api/v1/customers/:id" } } }
      ]
    },
    {
      "name": "Supplier",
      "item": [
        { "name": "Create Supplier", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Cookie", "value": "token={{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"businessName\": \"Supplier A\",\n  \"phone\": \"0912345678\"\n}" }, "url": { "raw": "{{baseUrl}}/api/v1/suppliers" } } },
        { "name": "List Suppliers", "request": { "method": "GET", "header": [{ "key": "Cookie", "value": "token={{token}}" }], "url": { "raw": "{{baseUrl}}/api/v1/suppliers" } } },
        { "name": "Get Supplier", "request": { "method": "GET", "header": [{ "key": "Cookie", "value": "token={{token}}" }], "url": { "raw": "{{baseUrl}}/api/v1/suppliers/:id" } } },
        { "name": "Update Supplier", "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Cookie", "value": "token={{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"businessName\": \"Supplier X\"\n}" }, "url": { "raw": "{{baseUrl}}/api/v1/suppliers/:id" } } },
        { "name": "Delete Supplier", "request": { "method": "DELETE", "header": [{ "key": "Cookie", "value": "token={{token}}" }], "url": { "raw": "{{baseUrl}}/api/v1/suppliers/:id" } } }
      ]
    },
    {
      "name": "Product",
      "item": [
        { "name": "Create Product", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Cookie", "value": "token={{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Coffee Beans\",\n  \"category\": \"{{categoryId}}\",\n  \"imageUrl\": \"http://localhost:3000/upload/coffee.png\",\n  \"costPrice\": 10,\n  \"salePrice\": 15\n}" }, "url": { "raw": "{{baseUrl}}/api/v1/products" } } },
        { "name": "List Products", "request": { "method": "GET", "header": [{ "key": "Cookie", "value": "token={{token}}" }], "url": { "raw": "{{baseUrl}}/api/v1/products" } } },
        { "name": "Get Product", "request": { "method": "GET", "header": [{ "key": "Cookie", "value": "token={{token}}" }], "url": { "raw": "{{baseUrl}}/api/v1/products/:id" } } },
        { "name": "Get Product By Code", "request": { "method": "GET", "header": [{ "key": "Cookie", "value": "token={{token}}" }], "url": { "raw": "{{baseUrl}}/api/v1/products/code/:code" } } },
        { "name": "Update Product", "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Cookie", "value": "token={{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"salePrice\": 18\n}" }, "url": { "raw": "{{baseUrl}}/api/v1/products/:id" } } },
        { "name": "Delete Product", "request": { "method": "DELETE", "header": [{ "key": "Cookie", "value": "token={{token}}" }], "url": { "raw": "{{baseUrl}}/api/v1/products/:id" } } }
      ]
    },
    {
      "name": "Purchase",
      "item": [
        { "name": "Create Purchase", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Cookie", "value": "token={{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"supplier\": \"{{supplierId}}\",\n  \"items\": []\n}" }, "url": { "raw": "{{baseUrl}}/api/v1/purchase" } } },
        { "name": "List Purchase", "request": { "method": "GET", "header": [{ "key": "Cookie", "value": "token={{token}}" }], "url": { "raw": "{{baseUrl}}/api/v1/purchase" } } },
        { "name": "Get Purchase", "request": { "method": "GET", "header": [{ "key": "Cookie", "value": "token={{token}}" }], "url": { "raw": "{{baseUrl}}/api/v1/purchase/:id" } } },
        { "name": "Update Purchase Status", "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Cookie", "value": "token={{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"status\": \"received\"\n}" }, "url": { "raw": "{{baseUrl}}/api/v1/purchase/updatePurchaseStatus/:id" } } },
        { "name": "Add Purchase Payment", "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Cookie", "value": "token={{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"paidAmount\": 50\n}" }, "url": { "raw": "{{baseUrl}}/api/v1/purchase/addPayment/:id" } } }
      ]
    },
    {
      "name": "Sale",
      "item": [
        { "name": "Create Sale", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Cookie", "value": "token={{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"customer\": \"{{customerId}}\",\n  \"items\": []\n}" }, "url": { "raw": "{{baseUrl}}/api/v1/sale" } } },
        { "name": "List Sale", "request": { "method": "GET", "header": [{ "key": "Cookie", "value": "token={{token}}" }], "url": { "raw": "{{baseUrl}}/api/v1/sale" } } },
        { "name": "Get Sale", "request": { "method": "GET", "header": [{ "key": "Cookie", "value": "token={{token}}" }], "url": { "raw": "{{baseUrl}}/api/v1/sale/find/:id" } } },
        { "name": "Check Stock", "request": { "method": "GET", "header": [{ "key": "Cookie", "value": "token={{token}}" }], "url": { "raw": "{{baseUrl}}/api/v1/sale/checkStock" } } },
        { "name": "Add Sale Payment", "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Cookie", "value": "token={{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"paidAmount\": 25\n}" }, "url": { "raw": "{{baseUrl}}/api/v1/sale/addPayment/:id" } } }
      ]
    },
    {
      "name": "Report",
      "item": [
        { "name": "General Report", "request": { "method": "GET", "header": [{ "key": "Cookie", "value": "token={{token}}" }], "url": { "raw": "{{baseUrl}}/api/v1/report/general" } } },
        { "name": "Sale Report", "request": { "method": "GET", "header": [{ "key": "Cookie", "value": "token={{token}}" }], "url": { "raw": "{{baseUrl}}/api/v1/report/sale?startDate=2026-05-01&endDate=2026-05-19" } } },
        { "name": "Stock Report", "request": { "method": "GET", "header": [{ "key": "Cookie", "value": "token={{token}}" }], "url": { "raw": "{{baseUrl}}/api/v1/report/stock?stockQty=10" } } },
        { "name": "30 Days Sales", "request": { "method": "GET", "header": [{ "key": "Cookie", "value": "token={{token}}" }], "url": { "raw": "{{baseUrl}}/api/v1/report/30daysAgo" } } }
      ]
    }
  ]
}
