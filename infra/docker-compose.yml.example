services:
  mongo:
    image: mongo:8
    restart: unless-stopped
    volumes:
      - kambuja_mongo_data:/data/db
    ports:
      - "27017:27017"

  api:
    build:
      context: ..
      dockerfile: apps/api/Dockerfile
    restart: unless-stopped
    depends_on:
      - mongo
    environment:
      MONGODB_URI: mongodb://mongo:27017/kambuja_pos
      SERVER_PORT: 8080
      MANAGEMENT_PORT: 8081
      JWT_SECRET: ${JWT_SECRET}
      JWT_EXPIRATION_MS: ${JWT_EXPIRATION_MS:-86400000}
      TELEGRAM_BOT_TOKEN: ${TELEGRAM_BOT_TOKEN}
      BOOTSTRAP_ADMIN_MANAGER_NAME: ${BOOTSTRAP_ADMIN_MANAGER_NAME:-Platform Manager}
      BOOTSTRAP_ADMIN_MANAGER_EMAIL: ${BOOTSTRAP_ADMIN_MANAGER_EMAIL:-manager@kambujaflow.local}
      BOOTSTRAP_ADMIN_MANAGER_PASSWORD: ${BOOTSTRAP_ADMIN_MANAGER_PASSWORD}
      CORS_ALLOWED_ORIGINS: ${CORS_ALLOWED_ORIGINS:-http://localhost:5173,http://localhost:5174}
    ports:
      - "8080:8080"

  web-admin-manager:
    build:
      context: ..
      dockerfile: apps/web-admin-manager/Dockerfile
      args:
        VITE_API_BASE_URL: /api
    restart: unless-stopped
    depends_on:
      - api
    ports:
      - "5173:80"

  web-admin:
    build:
      context: ..
      dockerfile: apps/web-admin/Dockerfile
      args:
        VITE_API_BASE_URL: /api
    restart: unless-stopped
    depends_on:
      - api
    ports:
      - "5174:80"

  prometheus:
    image: prom/prometheus:v3.4.1
    restart: unless-stopped
    depends_on:
      - api
    volumes:
      - ./monitoring/prometheus.yml:/etc/prometheus/prometheus.yml:ro
    ports:
      - "9090:9090"

volumes:
  kambuja_mongo_data:
